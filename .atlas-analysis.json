  "keyFeatures": [
    "Pure Kotlin DSL for intuitive stubbing and verification",
    "Mocking of final classes, objects, static methods, and constructors",
    "Coroutine support with co-prefixed DSL functions (coEvery, coVerify)",
    "Android support for both unit tests and instrumented tests",
    "Argument matchers and capturing with CapturingSlot",
    "Spy support to mix real and mocked behavior",
    "BDD-style aliases (given/then)",
    "JUnit 4 and JUnit 5 integration via rules and extensions",
    "Hierarchical and chained mock configuration",
    "Restricted mocking to enforce good testing practices"
  ],
  "publicApiSurface": [
